# ---------------------------------------------------------------------------
# Copy to .env.local and fill in. Do NOT commit real secrets.
# Keys WITHOUT the NEXT_PUBLIC_ prefix are server-only and never reach the browser.
# ---------------------------------------------------------------------------

# --- Database (Supabase Postgres via Prisma) ---
# Pooled connection (PgBouncer) used at runtime by the app
DATABASE_URL=postgresql://postgres:password@aws-region.pooler.supabase.com:5432/postgres
# Direct connection used for migrations / prisma db push
DIRECT_URL=postgresql://postgres:password@db.<project-ref>.supabase.co:5432/postgres

# --- Supabase Storage (event cover images) ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only — full access, keep secret

# --- Clerk auth ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx                       # server-only
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxx             # for /api/webhooks/clerk (user.deleted cleanup)

# --- App URL (used to build links in transactional emails) ---
# REQUIRED in production — without it email links point to http://localhost:3000
NEXT_PUBLIC_APP_URL=https://your-domain.com

# --- AutoSend transactional email ---
AUTOSEND_API_KEY=as_xxx                            # server-only
AUTOSEND_PROJECT_ID=                               # required only for org-admin (ASA_) keys
EMAIL_FROM=events@invytt.com
AUTOSEND_TEMPLATE1_ID=                             # guest RSVP confirmation
AUTOSEND_TEMPLATE2_ID=                             # host new-RSVP notification
AUTOSEND_TEMPLATE3_ID=                             # approval decision
AUTOSEND_TEMPLATE4_ID=                             # event invitation (Share → send email)

# --- Anthropic (AI "Fill with AI" event descriptions) ---
ANTHROPIC_API_KEY=sk-ant-xxx                       # server-only

# --- Google Maps (location autocomplete + map) ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-maps-key      # restrict by HTTP referrer in GCP console

# --- Observability (optional) ---
ERROR_WEBHOOK_URL=                                 # if set, server errors POST here (Slack, etc.)
