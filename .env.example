# --- Clerk auth ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Post-auth redirects
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# --- Google Maps Platform (browser key) ---
# Restrict by HTTP referrer + API allowlist: Maps JavaScript API, Places API (New), Geocoding API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza_xxx

# --- Postgres (Supabase) ---
# Transaction-mode pooler (IPv4) for the app
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true
# Session-mode pooler for Prisma migrations
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
