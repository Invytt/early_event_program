generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RsvpStatus {
  Going
  Pending
  Declined
  Waitlist
}

model Event {
  id              String   @id @default(cuid())
  ownerId         String // Clerk user id of the host
  name            String
  description     String?
  locationText    String?
  placeId         String?
  lat             Float?
  lng             Float?
  coverUrl        String?
  startsAt        DateTime
  timezone        String?
  capacity        Int?
  requireApproval Boolean  @default(false)
  hideLocation    Boolean  @default(false)
  // transactional email toggles (host-controlled per event)
  emailGuestRsvp  Boolean  @default(true) // confirmation email to guest on RSVP
  emailHostRsvp   Boolean  @default(true) // notification email to host on new RSVP
  emailDecision   Boolean  @default(true) // approve/decline email to guest
  slug            String   @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rsvps Rsvp[]

  @@index([ownerId])
}

model Rsvp {
  id         String     @id @default(cuid())
  eventId    String
  userId     String? // Clerk user id, if signed in
  guestName  String?
  guestEmail String?
  status     RsvpStatus @default(Going)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}
