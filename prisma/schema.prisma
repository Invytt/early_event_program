generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RsvpStatus {
  Going
  Pending
  Declined
  Waitlist
}

model Event {
  id              String   @id @default(cuid())
  ownerId         String // Clerk user id of the host
  name            String
  description     String?
  locationText    String?
  placeId         String?
  lat             Float?
  lng             Float?
  coverUrl        String?
  startsAt        DateTime
  timezone        String?
  capacity        Int?
  requireApproval Boolean  @default(false)
  hideLocation    Boolean  @default(false)
  // transactional email toggles (host-controlled per event)
  emailGuestRsvp  Boolean  @default(true) // confirmation email to guest on RSVP
  emailHostRsvp   Boolean  @default(true) // notification email to host on new RSVP
  emailDecision   Boolean  @default(true) // approve/decline email to guest
  // host-authored FAQ list: [{ q: string, a: string }, ...]
  faqs            Json?
  slug            String   @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rsvps     Rsvp[]
  questions Question[]

  @@index([ownerId])
}

model Rsvp {
  id         String     @id @default(cuid())
  eventId    String
  userId     String? // Clerk user id, if signed in
  guestName  String?
  guestEmail String?
  status     RsvpStatus @default(Going)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

// Open Q&A on an event: any signed-in viewer (host or guest) may post a
// question; anyone may answer. Posts are public the moment they're created.
model Question {
  id         String   @id @default(cuid())
  eventId    String
  authorId   String // Clerk user id of the asker
  authorName String?
  body       String
  createdAt  DateTime @default(now())

  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@index([eventId])
}

model Answer {
  id         String   @id @default(cuid())
  questionId String
  authorId   String // Clerk user id of the responder
  authorName String?
  body       String
  createdAt  DateTime @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}
