generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RsvpStatus {
  Going
  Pending
  Declined
  Waitlist
}

model Event {
  id              String   @id @default(cuid())
  ownerId         String // Clerk user id of the host
  name            String
  description     String?
  locationText    String?
  placeId         String?
  lat             Float?
  lng             Float?
  coverUrl        String?
  startsAt        DateTime
  timezone        String?
  capacity        Int?
  requireApproval Boolean  @default(false)
  hideLocation    Boolean  @default(false)
  // transactional email toggles (host-controlled per event)
  emailGuestRsvp  Boolean  @default(true) // confirmation email to guest on RSVP
  emailHostRsvp   Boolean  @default(true) // notification email to host on new RSVP
  emailDecision   Boolean  @default(true) // approve/decline email to guest
  // host-authored FAQ list: [{ q: string, a: string }, ...]
  faqs            Json?
  // host-authored questionnaire: ["question 1", "question 2", ...]
  questionnaire   Json?
  slug            String   @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rsvps     Rsvp[]
  responses QuestionnaireResponse[]

  @@index([ownerId])
}

model Rsvp {
  id         String     @id @default(cuid())
  eventId    String
  userId     String? // Clerk user id, if signed in
  guestName  String?
  guestEmail String?
  status     RsvpStatus @default(Going)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

// A guest's private answers to the host's questionnaire. Questions are public
// on the event page; answers are visible only to the host (in the dashboard
// responses list). One response row per guest per event (upserted).
model QuestionnaireResponse {
  id         String   @id @default(cuid())
  eventId    String
  userId     String // Clerk user id of the responder
  guestName  String?
  guestEmail String?
  answers    Json // [{ q: string, a: string }, ...]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
}
